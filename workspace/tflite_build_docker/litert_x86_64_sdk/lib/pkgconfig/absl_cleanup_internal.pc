prefix=/root/workspace/tflite_build_docker/install
exec_prefix=${prefix}
libdir=/root/workspace/tflite_build_docker/install/lib
includedir=/root/workspace/tflite_build_docker/install/include

Name: absl_cleanup_internal
Description: Abseil cleanup_internal library
URL: https://abseil.io/
Version: 20250127
Requires: absl_base_internal = 20250127, absl_core_headers = 20250127, absl_utility = 20250127
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX
