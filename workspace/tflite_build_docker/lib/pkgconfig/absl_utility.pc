prefix=/root/workspace/tflite_build_docker/install
exec_prefix=${prefix}
libdir=/root/workspace/tflite_build_docker/install/lib
includedir=/root/workspace/tflite_build_docker/install/include

Name: absl_utility
Description: Abseil utility library
URL: https://abseil.io/
Version: 20250127
Requires: absl_base_internal = 20250127, absl_config = 20250127, absl_type_traits = 20250127
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX
