prefix=/root/workspace/tflite_build_docker/install
exec_prefix=${prefix}
libdir=/root/workspace/tflite_build_docker/install/lib
includedir=/root/workspace/tflite_build_docker/install/include

Name: absl_cordz_statistics
Description: Abseil cordz_statistics library
URL: https://abseil.io/
Version: 20250127
Requires: absl_config = 20250127, absl_core_headers = 20250127, absl_cordz_update_tracker = 20250127, absl_synchronization = 20250127
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX
