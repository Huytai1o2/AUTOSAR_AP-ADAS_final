prefix=/root/workspace/tflite_build_docker/install
exec_prefix=${prefix}
libdir=/root/workspace/tflite_build_docker/install/lib
includedir=/root/workspace/tflite_build_docker/install/include

Name: absl_leak_check
Description: Abseil leak_check library
URL: https://abseil.io/
Version: 20250127
Requires: absl_config = 20250127, absl_core_headers = 20250127
Libs: -L${libdir}  -labsl_leak_check 
Cflags: -I${includedir} -DNOMINMAX
