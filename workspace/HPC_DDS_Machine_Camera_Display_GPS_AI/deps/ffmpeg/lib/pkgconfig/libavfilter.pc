prefix=/root/workspace/deps/ffmpeg
exec_prefix=${prefix}
libdir=/root/workspace/deps/ffmpeg/lib
includedir=/root/workspace/deps/ffmpeg/include

Name: libavfilter
Description: FFmpeg audio/video filtering library
Version: 9.12.100
Requires: libswscale >= 7.5.100, libavformat >= 60.16.100, libavcodec >= 60.31.102, libswresample >= 4.12.100, libavutil >= 58.29.100
Requires.private: 
Conflicts:
Libs: -L${libdir}  -lavfilter -pthread -lm -latomic
Libs.private: 
Cflags: -I${includedir}
