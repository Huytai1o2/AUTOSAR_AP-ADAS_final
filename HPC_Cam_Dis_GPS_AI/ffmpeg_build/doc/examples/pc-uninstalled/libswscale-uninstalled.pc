prefix=
exec_prefix=
libdir=${pcfiledir}/../../../libswscale
includedir=/root/workspace/ffmpeg

Name: libswscale
Description: FFmpeg image rescaling library
Version: 7.5.100
Requires:  libavutil >= 58.29.100
Conflicts:
Libs: -L${libdir} -Wl,-rpath,${libdir} -lswscale -lm -latomic
Cflags: -I${includedir}
